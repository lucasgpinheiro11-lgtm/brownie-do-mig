# ── Servidor ──────────────────────────────────────────────────────────────────
# Porta em que o backend vai escutar
PORT=3001

# ── Banco de dados ────────────────────────────────────────────────────────────
# Caminho do arquivo SQLite (relativo ao diretório backend/)
# Se omitido, usa ./brownie.db por padrão
DB_PATH=./brownie.db

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Chave secreta para assinar os tokens — troque por um valor longo e aleatório
# Exemplo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=troque-por-um-segredo-forte-aqui

# Tempo de expiração do token (padrão: 24h)
# Exemplos válidos: 15m, 2h, 7d
JWT_EXPIRES=24h
