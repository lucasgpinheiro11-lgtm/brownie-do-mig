# ── Ambiente ──────────────────────────────────────────────────────────────────
# "development" (padrão) ou "production"
# Em produção, o Express serve o frontend buildado em frontend/dist/
NODE_ENV=development

# ── Servidor ──────────────────────────────────────────────────────────────────
# Porta em que o backend vai escutar (o Render define isso automaticamente)
PORT=3001

# ── Banco de dados ────────────────────────────────────────────────────────────
# Caminho do arquivo SQLite.
# Dev:        ./brownie.db  (criado ao lado de server.js)
# Render:     /data/brownie.db  (disco persistente montado em /data)
DB_PATH=./brownie.db

# ── Autenticação JWT ──────────────────────────────────────────────────────────
# Chave secreta para assinar os tokens — troque por um valor longo e aleatório
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# No Render, use "generateValue: true" no render.yaml — ele gera automaticamente
JWT_SECRET=troque-por-um-segredo-forte-aqui

# Tempo de expiração do token (padrão: 24h)
# Exemplos válidos: 15m, 2h, 7d
JWT_EXPIRES=24h

# ── Z-API (cobranças WhatsApp) ────────────────────────────────────────────────
# Instance ID e Token gerados no painel da Z-API (https://app.z-api.io)
ZAPI_INSTANCE_ID=sua-instance-id-aqui
ZAPI_TOKEN=seu-token-aqui
# Client-Token: encontrado em Segurança no painel Z-API (obrigatório se Security estiver ativado)
ZAPI_CLIENT_TOKEN=seu-client-token-aqui
